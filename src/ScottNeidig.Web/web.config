<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS / Plesk hosting config. Publish fills in processPath and arguments; the part we set by
  hand is the environment name, so the app loads appsettings.Production.json and runs the real
  error handler and HSTS instead of the developer exception page.
  The connection string and admin secrets are NOT here: they live in appsettings.Production.json,
  which is FTP'd separately and never committed.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\ScottNeidig.Web.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
