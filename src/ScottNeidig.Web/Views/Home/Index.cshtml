@using ScottNeidig.Web.Models
@model HomeViewModel

@*
    Copy here is placeholder-quality and Scott's call to rewrite. It's deliberately
    understated: claims have to be ones that survive a client conversation. No "hand-written"
    claim (he guides AI to write code; claiming hand-coded is false and the first thing a
    client interview would expose). Services-led, not portfolio-led, per the IA.
*@

<section class="section--lede">
    <div class="container">
        <p class="topper">Web and application developer</p>
        <h1 class="header">Development for businesses and organizations</h1>
        <p class="text lede__text">
            I build and maintain .NET applications, nopCommerce stores, and websites for small
            businesses. Real development on live systems, fast and built to last, by someone
            who's done this inside agencies for years.
        </p>
        <a class="button button--lg" asp-controller="Contact" asp-action="Index">Schedule a consultation</a>
    </div>
</section>

<section class="section--alt">
    <div class="container">
        <p class="topper">What I do</p>
        <h2 class="title">How I can help</h2>

        @* Each offer links into its service page. Order matches the services hub:
           nopCommerce first (sharpest wedge), .NET second, websites last. *@
        <ul class="offers">
            <li>
                <a class="offer" asp-controller="Services" asp-action="NopCommerce">
                    <h3 class="offer__title">nopCommerce development</h3>
                    <p class="offer__text">
                        Custom plugins, integrations, upgrades and fixes on existing stores.
                        Agency experience, working with you directly.
                    </p>
                    @* Decorative: the whole card is one link named by the h3, so this repeat
                       is hidden from screen readers to avoid announcing the title twice. *@
                    <span class="offer__more" aria-hidden="true">Learn more</span>
                </a>
            </li>

            <li>
                <a class="offer" asp-controller="Services" asp-action="DotNet">
                    <h3 class="offer__title">.NET application development</h3>
                    <p class="offer__text">
                        Maintenance, fixes and new features on an existing .NET application, or
                        a new build. The back end, not just the front. 25 years of it.
                    </p>
                    <span class="offer__more" aria-hidden="true">Learn more</span>
                </a>
            </li>

            <li>
                <a class="offer" asp-controller="Services" asp-action="SmallBusiness">
                    <h3 class="offer__title">Small business websites</h3>
                    <p class="offer__text">
                        A fast, clean site built to be found by people searching for what you do.
                    </p>
                    <span class="offer__more" aria-hidden="true">Learn more</span>
                </a>
            </li>
        </ul>
    </div>
</section>

@if (Model.FeaturedProjects.Count > 0)
{
    <section>
        <div class="container">
            <p class="topper">Work</p>
            <h2 class="title">Recent builds</h2>

            <ul class="cards">
                @foreach (var project in Model.FeaturedProjects)
                {
                    @* h3: the "Recent builds" h2 sits above this grid, so h2 here would skip
                       nothing but would flatten the outline. *@
                    <partial name="_ProjectCard" model="@(new ProjectCardModel
                            {
                                Project = project,
                                HeadingLevel = 3
                            })" />
                }
            </ul>

            <p class="cards__more">
                <a asp-controller="Work" asp-action="Index">See all work</a>
            </p>
        </div>
    </section>
}
