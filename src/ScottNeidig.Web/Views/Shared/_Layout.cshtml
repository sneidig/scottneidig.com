@*
    Base layout.

    CSS loading follows the CodeStitch Page Speed Handbook:
      - critical.css loads normally (above-the-fold styles + design tokens)
      - main.css is deferred via the media="print" onload trick so it doesn't render-block
      - <noscript> fallback loads main.css for JS-disabled browsers
    Analytics, when added, goes at the BOTTOM of <head> right above <title> (render blocking).
*@
@inject Microsoft.Extensions.Options.IOptions<ScottNeidig.Web.Configuration.SiteOptions> Site
@{
    var site = Site.Value;

    // Configured BaseUrl wins so a canonical host can be pinned; otherwise the request origin,
    // which is right for local dev. Matches SeoController.Origin().
    var origin = !string.IsNullOrWhiteSpace(site.BaseUrl)
        ? site.BaseUrl.TrimEnd('/')
        : $"{Context.Request.Scheme}://{Context.Request.Host}";

    // Canonical is path-only (query stripped) so filtered/tracked variants don't read as
    // separate pages.
    var canonical = origin + Context.Request.Path;

    var pageTitle = ViewData["Title"] as string;
    var fullTitle = string.IsNullOrWhiteSpace(pageTitle) ? site.SiteName : $"{pageTitle} | {site.SiteName}";
    var description = ViewData["Description"] as string ?? "";

    // Serialized rather than hand-written so the JSON is always valid, and the serializer's
    // default encoder escapes any < > & so it can't break out of the script element.
    // Keys must serialize as "@context"/"@type" for valid JSON-LD. Inside this code block the
    // @ in a string literal is a literal character (Razor only reparses @ in markup regions),
    // so no escaping is needed. Serialized rather than hand-written so the JSON is always valid.
    // address (city/region) and areaServed are the local-SEO signals: they tell search engines
    // where he is and which areas he covers.
    var personJsonLd = System.Text.Json.JsonSerializer.Serialize(new Dictionary<string, object>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Person",
        ["name"] = site.PersonName,
        ["url"] = origin,
        ["jobTitle"] = site.JobTitle,
        ["address"] = new Dictionary<string, object>
        {
            ["@type"] = "PostalAddress",
            ["addressLocality"] = site.Locality,
            ["addressRegion"] = site.Region,
            ["addressCountry"] = "US",
        },
        ["areaServed"] = site.AreasServed,
    });
}
<!DOCTYPE html>
@* Light is the default theme. The dark palette stays in critical.css under :root as the
   alternate, ready if a toggle is added later. *@
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@description" />

    <link rel="canonical" href="@canonical" />

    @* Open Graph + Twitter, so a shared link renders a proper card. No og:image yet: there's
       no share asset. Add one (1200x630) and an og:image tag when it exists. *@
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@site.SiteName" />
    <meta property="og:title" content="@fullTitle" />
    <meta property="og:description" content="@description" />
    <meta property="og:url" content="@canonical" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="@fullTitle" />
    <meta name="twitter:description" content="@description" />

    <script type="application/ld+json">@Html.Raw(personJsonLd)</script>

    <link rel="stylesheet" href="~/css/critical.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true"
          media="print" onload="this.media='all'; this.onload=null;" />
    <noscript><link rel="stylesheet" href="~/css/main.css" asp-append-version="true" /></noscript>

    @* Per-page head additions, e.g. a blog post's Article JSON-LD. *@
    @await RenderSectionAsync("Head", required: false)

    <title>@fullTitle</title>
</head>
<body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
        <nav class="site-nav" aria-label="Main">
            <a class="site-nav__brand" asp-controller="Home" asp-action="Index">Scott Neidig</a>

            @*
                Services dropdown. Native <details>/<summary>: a click/touch-friendly,
                keyboard-accessible menu with zero JavaScript, which is why it's this element
                and not a hover menu (hover doesn't work on touch) or a JS widget. The summary
                is the toggle; the hub link lives inside as "All services" since a <summary>
                can't also be a link. About and Blog join as siblings when they're built.

                No Contact link: the "Schedule a consultation" CTA already goes there, so a
                second Contact entry would be redundant. The CTA is a button and sits far right
                so it reads as the one primary action. The header is sticky (critical.css), so
                it all stays on screen the whole way down the page.
            *@
            <details class="nav-menu">
                <summary class="nav-menu__label">Services</summary>
                <ul class="nav-menu__list">
                    <li><a asp-controller="Services" asp-action="Index">All services</a></li>
                    <li><a asp-controller="Services" asp-action="NopCommerce">nopCommerce</a></li>
                    <li><a asp-controller="Services" asp-action="DotNet">.NET applications</a></li>
                    <li><a asp-controller="Services" asp-action="SmallBusiness">Websites</a></li>
                </ul>
            </details>

            <a class="site-nav__link" asp-controller="About" asp-action="Index">About</a>
            <a class="site-nav__link" asp-controller="Blog" asp-action="Index">Blog</a>

            <a class="button site-nav__cta" asp-controller="Contact" asp-action="Index">Schedule a consultation</a>
        </nav>
    </header>

    <main id="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        @* Footer carries the fuller nav, including the services hub and Work, which are kept
           out of the top nav to keep it focused. Grows as About/Blog land. *@
        <nav class="footer-nav" aria-label="Footer">
            <a asp-controller="Services" asp-action="Index">Services</a>
            <a asp-controller="About" asp-action="Index">About</a>
            <a asp-controller="Work" asp-action="Index">Work</a>
            <a asp-controller="Blog" asp-action="Index">Blog</a>
            <a asp-controller="Contact" asp-action="Index">Contact</a>
        </nav>
        @* Location in the footer is an honest local-SEO signal and appears on every page. *@
        <p class="site-footer__location">
            Web developer in @site.Locality, @site.Region. Serving the Denver metro and the
            Colorado Front Range.
        </p>
        <p>&copy; @DateTime.UtcNow.Year Scott Neidig</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
