@*
    Base layout.

    CSS loading follows the CodeStitch Page Speed Handbook:
      - critical.css loads normally (above-the-fold styles + design tokens)
      - main.css is deferred via the media="print" onload trick so it doesn't render-block
      - <noscript> fallback loads main.css for JS-disabled browsers
    Analytics, when added, goes at the BOTTOM of <head> right above <title> (render blocking).
*@
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@ViewData["Description"]" />

    <link rel="stylesheet" href="~/css/critical.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true"
          media="print" onload="this.media='all'; this.onload=null;" />
    <noscript><link rel="stylesheet" href="~/css/main.css" asp-append-version="true" /></noscript>

    <title>@ViewData["Title"] | Scott Neidig</title>
</head>
<body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
        <nav class="site-nav" aria-label="Main">
            <a class="site-nav__brand" asp-controller="Home" asp-action="Index">Scott Neidig</a>

            <ul class="site-nav__links">
                <li><a asp-controller="Work" asp-action="Index">Work</a></li>
            </ul>
        </nav>
    </header>

    <main id="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <p>&copy; @DateTime.UtcNow.Year Scott Neidig</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
