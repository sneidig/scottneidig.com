@model ErrorViewModel

<section class="section--lede">
    <div class="container container--prose">
        <p class="topper">Error</p>
        <h1 class="header">Something went wrong</h1>
        <p class="text lede__text">
            A problem on my end, not yours. It's been logged and I'll look into it. Try again in
            a moment, or head back home.
        </p>

        <p>
            <a class="button" asp-controller="Home" asp-action="Index">Back to home</a>
        </p>

        @if (Model.ShowRequestId)
        {
            @* Only useful if someone reports the error; harmless to show and helps me trace it. *@
            <p class="text"><small>Reference: <code>@Model.RequestId</code></small></p>
        }
    </div>
</section>
