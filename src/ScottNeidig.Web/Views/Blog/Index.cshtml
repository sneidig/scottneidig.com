@using ScottNeidig.Web.Services
@model List<BlogListItem>

<section class="section--lede">
    <div class="container container--prose">
        <p class="topper">Blog</p>
        <h1 class="header">Writing</h1>
        <p class="text lede__text">
            Notes on nopCommerce, .NET, and building for the web.
        </p>
    </div>
</section>

<section>
    <div class="container container--prose">
        @if (Model.Count == 0)
        {
            <p class="text">No posts yet. Check back soon.</p>
        }
        else
        {
            <ul class="post-list">
                @foreach (var post in Model)
                {
                    <li class="post-item">
                        <h2 class="post-item__title">
                            <a asp-action="Post" asp-route-slug="@post.Slug">@post.Title</a>
                        </h2>

                        @if (post.PublishedUtc is { } published)
                        {
                            <p class="post-item__date">
                                <time datetime="@published.ToString("yyyy-MM-dd")">
                                    @published.ToString("d MMMM yyyy")
                                </time>
                            </p>
                        }

                        @if (!string.IsNullOrWhiteSpace(post.Excerpt))
                        {
                            <p class="post-item__excerpt">@post.Excerpt</p>
                        }
                    </li>
                }
            </ul>
        }
    </div>
</section>
