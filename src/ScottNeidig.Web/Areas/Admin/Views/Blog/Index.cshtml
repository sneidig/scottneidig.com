@using ScottNeidig.Web.Services
@model List<BlogPostSummary>

<section>
    <div class="container">
        <p class="topper">Admin</p>
        <h1 class="title">Blog</h1>

        <a class="button" asp-action="Create">New post</a>

        @if (Model.Count == 0)
        {
            <p class="text">No posts yet.</p>
        }
        else
        {
            <table class="table">
                <caption class="visually-hidden">Blog posts, newest first</caption>
                <thead>
                    <tr>
                        <th scope="col">Title</th>
                        <th scope="col">URL</th>
                        <th scope="col">Published</th>
                        <th scope="col">Status</th>
                        <th scope="col"><span class="visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr>
                            <td>@post.Title</td>
                            <td><code>/blog/@post.Slug</code></td>
                            <td>@(post.PublishedUtc?.ToLocalTime().ToString("d MMM yyyy") ?? "—")</td>
                            <td>
                                <span class="badge @(post.Published ? "badge--live" : "badge--draft")">
                                    @(post.Published ? "Published" : "Draft")
                                </span>
                            </td>
                            <td>
                                <div class="table__actions">
                                    <a asp-action="Edit" asp-route-id="@post.Id">Edit</a>

                                    <form asp-action="Delete" asp-route-id="@post.Id" method="post"
                                          onsubmit="return confirm('Delete @post.Title? This cannot be undone.');">
                                        <button class="button--link" type="submit">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</section>
