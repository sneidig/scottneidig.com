@model LoginViewModel

<section>
    <div class="container container--narrow">
        <h1 class="title">Sign in</h1>

        <form method="post" class="form">
            <div asp-validation-summary="ModelOnly" class="form__errors" role="alert"></div>

            <input type="hidden" asp-for="ReturnUrl" />

            <div class="form__field">
                <label asp-for="Email"></label>
                <input asp-for="Email" autocomplete="username" autofocus />
                <span asp-validation-for="Email" class="form__error"></span>
            </div>

            <div class="form__field">
                <label asp-for="Password"></label>
                <input asp-for="Password" autocomplete="current-password" />
                <span asp-validation-for="Password" class="form__error"></span>
            </div>

            <div class="form__field form__field--inline">
                <input asp-for="RememberMe" />
                <label asp-for="RememberMe">Stay signed in</label>
            </div>

            <button class="button" type="submit">Sign in</button>
        </form>
    </div>
</section>
